# ─── iDeep WhatsApp Bot — example environment ────────────────────────────────
# Copy this file to `.env` and fill in your values.

# ─── Core ───────────────────────────────────────────────────────────────────
APP_VERSION=1.2.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ─── Security ───────────────────────────────────────────────────────────────
# If unset, a random key is generated on every restart (you'll be locked out).
API_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string

# ─── Storage paths ──────────────────────────────────────────────────────────
WA_DATABASE_PATH=/app/data/whatsapp.db
WA_STORE_PATH=/app/data
APP_DB_PATH=/app/data/app.db
MESSAGE_STORE_DB=/app/data/messages.db
LOG_FILE=/app/data/logs/app.log

# ─── Assistant defaults (live values stored in DB after first run) ──────────
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MESSAGE=Hi, I am iDeep AI Assistant. I'll get back to you shortly.
ASSISTANT_NAME=iDeep AI

# ─── LLM-powered replies ────────────────────────────────────────────────────
# LLM_PROVIDER: none | openai | anthropic
LLM_PROVIDER=none

# OpenAI: gpt-4o-mini, gpt-4o, gpt-4.1-mini, ...
# Anthropic: claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-7, ...
LLM_MODEL=gpt-4o-mini

# Your provider API key (sk-... for OpenAI, sk-ant-... for Anthropic)
LLM_API_KEY=

# Optional override (e.g. https://openrouter.ai/api/v1, Azure proxy, etc.)
# Leave blank to use the provider's default endpoint.
LLM_BASE_URL=

# Default system prompt. Per-contact personas can override this.
LLM_SYSTEM_PROMPT=You are iDeep AI Assistant, replying on behalf of the user on WhatsApp. Keep replies short, friendly, and human. Never reveal you are an AI unless directly asked.

LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.7
LLM_HISTORY_SIZE=8
LLM_TIMEOUT_SECONDS=20

# ─── Scheduler ──────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=20

# ─── Quiet hours (live values stored in DB) ─────────────────────────────────
# IANA timezone name, e.g. "Europe/Istanbul", "Asia/Tehran", "UTC".
QUIET_HOURS_TIMEZONE=UTC

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
