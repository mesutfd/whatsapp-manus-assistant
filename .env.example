###############################################################################
# iDeep WhatsApp Bot API - Environment Configuration
# Copy this file to .env and fill in real values. Do NOT commit .env.
#   cp .env.example .env
###############################################################################

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME="iDeep WhatsApp Bot API"
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ─── Security (REQUIRED) ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=replace-me-with-a-strong-random-token

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-strong-random-token
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=720

# ─── WhatsApp ────────────────────────────────────────────────────────────────
WA_SESSION_NAME=ideep_whatsapp
WA_DATABASE_PATH=./data/whatsapp.db
WA_STORE_PATH=./data

# ─── Auto-Reply (iDeep AI Assistant) ─────────────────────────────────────────
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MESSAGE="Hi, I am iDeep AI Assistant. The owner is not available right now and will get back to you soon."
ASSISTANT_NAME="iDeep AI"

# ─── Message Store ───────────────────────────────────────────────────────────
MESSAGE_STORE_ENABLED=true
MESSAGE_STORE_DB=./data/messages.db
MAX_STORED_MESSAGES=10000

# ─── Webhooks (optional, for n8n / Manus / external integrations) ────────────
# WEBHOOK_URL=https://your-n8n-instance.com/webhook/whatsapp
# WEBHOOK_SECRET=your-webhook-secret
# WEBHOOK_EVENTS=message,status,connection

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_ENABLED=true

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/app.log
